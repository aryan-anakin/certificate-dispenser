# ─────────────────────────────────────────────────────────────────────────────
# Certificate Dispenser — environment template
#
# SETUP:  cp .env.example .env.local   then fill in the values below.
# Full step-by-step guide (where each value comes from):  docs/SETUP.md
#
# .env.local is gitignored — never commit it. Restart `npm run dev` after edits.
# [REQUIRED] = needed to send certificates.  [optional] = has a safe default.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Supabase dashboard → Project Settings → API
# [REQUIRED] "Project URL"
NEXT_PUBLIC_SUPABASE_URL=
# [REQUIRED] "Project API keys" → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# [REQUIRED] "Project API keys" → service_role.  SERVER ONLY — bypasses RLS,
# never expose to the client or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# ── Resend (email) ───────────────────────────────────────────────────────────
# [REQUIRED] Resend dashboard → API Keys → Create API Key. Starts with "re_".
RESEND_API_KEY=
# [optional] Sender. The default below works with NO domain setup, but Resend
# will only DELIVER to the email your Resend account is registered with.
# To send to anyone else, verify a domain in Resend and use an address on it.
RESEND_FROM_EMAIL=onboarding@resend.dev
# [optional] Display name recipients see as the sender.
RESEND_FROM_NAME=Your Organization

# ── App ──────────────────────────────────────────────────────────────────────
# [REQUIRED] Public base URL used to build verification + QR links (NO trailing
# slash). Local dev = http://localhost:3000. In prod, your real domain.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# [REQUIRED] Secret protecting POST /api/worker/tick (sent as
# `Authorization: Bearer <secret>`). Generate one:  openssl rand -hex 32
CRON_SECRET=change-me-to-a-long-random-string
# [optional] Where the send worker pings (overrides NEXT_PUBLIC_APP_URL for the
# worker ONLY). Set this to drain a DEPLOYED app from your laptop. Use the
# canonical URL — a redirecting URL strips the auth header and causes 401s.
# Guide:  docs/WORKER.md
# WORKER_URL=https://your-app.example.com
# [optional] Admin password gate for the dashboard. If left blank, the
# dashboard runs OPEN (fine for local dev; set a value before deploying).
ADMIN_PASSWORD=
